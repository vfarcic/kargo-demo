{
  "packages": [
    "kubectl@1.29.2",
    "kind@0.22.0",
    "kubernetes-helm@3.14.2",
    "bat@0.24.0"
  ],
  "shell": {
    "init_hook": [
      "alias cat='bat --paging never --theme DarkNeon --style plain'"
    ],
    "scripts": {
      "youtube-release": [
        "eval \"$(teller sh)\"",
        "youtube-release"
      ]
    }
  }
}
